# Path to Firebase service account JSON on the machine running worker
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Run every N minutes
WORKER_INTERVAL_MINUTES=15

# Fetch newest N emails each cycle (1..100)
WORKER_LIMIT=5

# OAuth callback listener for local OpenAI login flow
OAUTH_CALLBACK_PORT=1455

# Optional: comma-separated Firebase user IDs to fetch for.
# If empty, worker scans all users that have /config/default
WORKER_USER_IDS=

# Firestore lease document path to prevent multiple machines running duplicate cycles
WORKER_LEASE_DOC_PATH=system/workerLease/global
